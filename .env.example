# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://your-app.vercel.app

# ─── Auth (Clerk) ────────────────────────────────────────────────────────────
CLERK_JWKS_URI=https://grown-lionfish-89.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://grown-lionfish-89.clerk.accounts.dev

# ─── TypeORM ─────────────────────────────────────────────────────────────────
# Set to "true" ONLY in local dev. Never in production — use migrations instead.
TYPEORM_SYNCHRONIZE=false

# ─── Tenant ──────────────────────────────────────────────────────────────────
DEFAULT_TENANT_ID=

# ─── Admin seed (protect this!) ──────────────────────────────────────────────
ADMIN_SEED_SECRET=change-me-to-something-long-and-random

# ─── AI ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=no-reply@your-domain.com

# ─── Swagger (only enable for debugging — never in production by default) ────
ENABLE_SWAGGER=false
